{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${mod_version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
        "${mod_authors}"
    ],
    "icon": "assets/inkraft/logo.png",
    "contact": {
        "sources": "${mod_sources}",
        "issues": "${mod_issues_page}"
    },
    "license": "${mod_license}",
    "environment": "*",
    "entrypoints": {
        "main": [
            "cx.rain.mc.inkraft.fabric.InkraftFabric"
        ]
    },
    "mixins": [
        "inkraft.mixins.json",
        "inkraft-fabric.mixins.json"
    ],
    "depends": {
        "minecraft": "${fabric_minecraft_version_range}",
        "fabricloader": "${fabric_loader_version_range}",
        "fabric-api": "${fabric_api_version_range}",
        "adventure-platform-fabric": "${fabric_adventure_platform_version_range}"
    }
}
